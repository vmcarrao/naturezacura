rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DEFAULT DENY — nothing is accessible from the client unless explicitly allowed.
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Allow public users to subscribe to the newsletter
    match /newsletter/{email} {
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt']) 
                    && request.resource.data.email is string;
    }

    // Owner-only read access for the Admin Dashboard
    function isOwner() {
      return request.auth != null && request.auth.token.email == "naturezacura@naturezacura.net";
    }

    match /orders/{orderId} {
      allow read: if isOwner();
    }
    
    match /appointments/{appointmentId} {
      allow read: if isOwner();
    }
    
    match /newsletter/{email} {
      allow read: if isOwner();
    }
    
    // Rate limit collection is handled via Admin SDK (functions) so client access remains false by default.
  }
}
