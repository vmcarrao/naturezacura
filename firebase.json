{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "tailwind.config.js",
      "input.css",
      "setup_guide.md",
      "functions/**",
      "**/.env*",
      "**/serviceAccountKey.json"
    ],
    "redirects": [
      {
        "destination": "https://www.naturezacura.net/:1",
        "type": 301,
        "regex": "^/(.*)$"
      }
    ]
  },
  "functions": {
    "source": "functions"
  }
}